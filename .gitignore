# =============================================
# SECRETS — NEVER COMMIT THESE
# =============================================
# Environment variables (database passwords, API keys, etc.)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Confluent Cloud Kafka credentials
client.properties

# Generic credential files
*.pem
*.key
*.cert
secrets/
credentials/

# =============================================
# NODE.JS / NPM
# =============================================
# Installed packages — restored by `npm install`
node_modules/

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Yarn integrity file
.yarn-integrity

# =============================================
# NESTJS / TYPESCRIPT BUILD OUTPUT
# =============================================
# Compiled JS output from `nest build`
dist/

# TypeScript incremental compile cache
*.tsbuildinfo

# =============================================
# TESTING / COVERAGE
# =============================================
coverage/
.nyc_output/
*.lcov

# =============================================
# LOGS
# =============================================
logs/
*.log

# =============================================
# IDE / EDITOR
# =============================================
# VS Code (keep .vscode/settings.json shared if your team agrees,
# but ignore personal launch configs and history)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.history/

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================
# OPERATING SYSTEM
# =============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# =============================================
# RUNTIME / TEMP
# =============================================
# Process IDs and runtime data
pids/
*.pid
*.seed
*.pid.lock

# Optional REPL history
.node_repl_history

# Output of `npm pack`
*.tgz

# Temporary folders
tmp/
temp/

# =============================================
# DEPLOYMENT / DOCKER (optional, uncomment if used)
# =============================================
# .dockerignore is committed; this is for runtime artifacts
# docker-compose.override.yml