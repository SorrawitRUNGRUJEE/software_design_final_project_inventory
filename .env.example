# =============================================
# SERVER CONFIG
# =============================================
PORT=3000

# =============================================
# SUPABASE / POSTGRES DATABASE
# =============================================
# Get these from: Supabase Dashboard → Project Settings → Database
DATABASE_HOST=your-project.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your-password
DATABASE_NAME=postgres
DATABASE_SSL=true

# =============================================
# KAFKA CONFIG
# =============================================
# Confluent Cloud connection details are read from `client.properties` file at the project root.
# That file should be obtained from your classmate who set up Confluent Cloud.
# No bootstrap-servers or credentials needed here — they all live in client.properties.

# Group ID and offset reset for the consumer
KAFKA_CONSUMER_GROUP=inventory-catalog-group
KAFKA_AUTO_OFFSET_RESET=earliest

# =============================================
# KAFKA TOPICS — PUBLISHED BY YOUR SERVICE
# Other teams subscribe to these
# =============================================

# Inventory & Legal report inspection result back to CEO
TOPIC_PROPERTY_EXAMINED=inventory.property.examined

# Inventory finalizes price during acquisition → Marketing, CEO consume
# NOTE: Marketing team's dev doc shows "inventory.price.settled" — keeping consistent here
TOPIC_PRICE_SETTLED=inventory.price.settled

# Inventory saves property into the system → Sales consumes
TOPIC_PROPERTY_REGISTERED=inventory.property.registered

# Inventory finalizes property after Step 4 (Finalize & Submit) → Sales consumes
TOPIC_PROPERTY_FINALIZED=inventory.property.finalized

# Defect report submitted by staff → Post-Sale consumes
TOPIC_DEFECT_REPORT_RECEIVED=inventory.defect.received

# =============================================
# KAFKA TOPICS — CONSUMED FROM OTHER TEAMS
# Names taken from the latest dev document
# ⚠️ Confirm exact name with CEO/Managing team for "property.survey"
# =============================================

# From CEO/Managing team — initial property survey shared with multiple teams
TOPIC_PROPERTY_SURVEY=ceo.property.surveyed

# From Payment team — property purchase confirmed
TOPIC_PROPERTY_BOUGHT=payment.propertybought.completed

# From Payment team — second payment confirmed
TOPIC_SECOND_PAYMENT=payment.secondpayment.completed

# From Sales & Booking team
TOPIC_QUOTATION_CREATED=sale.quotationcreated.complete
TOPIC_RESERVATION_CREATED=sale.reservationcreated.complete
TOPIC_BOOKING_CREATED=sale.booked.complete
